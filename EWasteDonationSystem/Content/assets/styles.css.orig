:root{
  --bg1:#e0f2fe;
  --bg2:#f5f3ff;
  --panel:#ffffff;
  --panel2:#ffffff;
  --text:#0b1224;
  --muted:#475569;
  --brand:#2dd4bf;
  --brand2:#60a5fa;
  --brand3:#a78bfa;
  --ok:#10b981;
  --warn:#f59e0b;
  --bad:#ef4444;
  --stroke: rgba(15, 23, 42, .10);
  --shadow: 0 18px 50px rgba(15, 23, 42, .12);
  --radius: 22px;
  --radius2: 16px;
  --font: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
}

*{box-sizing:border-box}
html,body{height:100%}
body{
  margin:0;
  font-family: var(--font);
  background:
    radial-gradient(900px 600px at 12% 10%, rgba(45,212,191,.20), transparent 60%),
    radial-gradient(900px 600px at 88% 14%, rgba(96,165,250,.20), transparent 60%),
    radial-gradient(1200px 800px at 50% 100%, rgba(167,139,250,.16), transparent 55%),
    linear-gradient(180deg, var(--bg1) 0%, #ffffff 45%, var(--bg2) 100%);
  color: var(--text);
}

a{color:inherit; text-decoration:none}
.container{max-width:1120px; margin:0 auto; padding:26px}
.topbar{
  display:flex; align-items:center; justify-content:space-between;
  padding:18px 22px; border:1px solid var(--stroke); border-radius: var(--radius);
  background: rgba(255,255,255,.78); backdrop-filter: blur(10px);
  box-shadow: var(--shadow);
}
.brand{
  display:flex; gap:12px; align-items:center;
}
.logo{
  width:44px;height:44px;border-radius: 16px;
  background: linear-gradient(135deg, var(--brand), var(--brand2), var(--brand3));
  box-shadow: 0 16px 30px rgba(15, 23, 42, .10);
  display:grid; place-items:center;
}
.logo img{width:28px;height:28px}
.brand h1{font-size:16px; margin:0; letter-spacing:.2px}
.brand p{margin:2px 0 0; font-size:12px; color: var(--muted)}
.nav{
  display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end
}
.chip{
  padding:8px 12px; border:1px solid var(--stroke); border-radius: 999px;
  background: rgba(15, 23, 42, .03); color: var(--muted);
  font-size:12px;
}
.hero{
  margin-top:18px;
  padding:26px; border-radius: var(--radius);
  border:1px solid var(--stroke);
  background: rgba(255,255,255,.78);
  box-shadow: var(--shadow);
  display:grid; grid-template-columns: 1.2fr .8fr; gap:18px;
}
.hero h2{margin:0 0 10px; font-size:30px; line-height:1.12}
.hero p{margin:0; color: var(--muted); line-height:1.6}
.heroart{
  border-radius: 18px;
  border:1px solid var(--stroke);
  background: linear-gradient(135deg, rgba(45,212,191,.10), rgba(96,165,250,.10), rgba(167,139,250,.10));
  overflow:hidden;
  box-shadow: 0 14px 36px rgba(15, 23, 42, .08);
}
.heroart img{width:100%; height:100%; display:block; object-fit:cover}

.kpis{
  display:grid; gap:12px;
}
.kpi{
  padding:14px; border-radius: var(--radius2);
  border:1px solid var(--stroke);
  background: rgba(15, 23, 42, .02);
}
.kpi .label{font-size:12px; color: var(--muted)}
.kpi .value{font-size:20px; font-weight:800; margin-top:6px}

.grid{
  margin-top:18px;
  display:grid;
  grid-template-columns: 1fr 1fr;
  gap:18px;
}
.card{
  border:1px solid var(--stroke);
  border-radius: var(--radius);
  background: rgba(255,255,255,.78);
  box-shadow: var(--shadow);
  overflow:hidden;
}
.card .head{
  padding:18px 18px 12px;
  border-bottom:1px solid var(--stroke);
  background: linear-gradient(180deg, rgba(45,212,191,.12), rgba(255,255,255,0));
}
.card .head h3{margin:0; font-size:16px}
.card .head p{margin:8px 0 0; font-size:12px; color: var(--muted); line-height:1.5}
.card .body{padding:18px}

.btnrow{display:flex; gap:10px; flex-wrap:wrap}
.btn{
  border:0; cursor:pointer;
  padding:12px 14px; border-radius: 16px;
  font-weight:750; letter-spacing:.15px;
  background: rgba(15, 23, 42, .04);
  color: var(--text);
  border:1px solid var(--stroke);
  transition: transform .08s ease, background .2s ease, border-color .2s ease, box-shadow .2s ease;
}
.btn:hover{transform: translateY(-1px); background: rgba(15, 23, 42, .06); box-shadow: 0 10px 24px rgba(15,23,42,.08)}
.btn.primary{
  background: linear-gradient(135deg, var(--brand) 0%, var(--brand2) 50%, var(--brand3) 100%);
  color: #07111f;
  border-color: transparent;
}
.btn.ghost{
  background: transparent;
}
.btn.ok{background: rgba(16,185,129,.10); border-color: rgba(16,185,129,.30)}
.btn.bad{background: rgba(239,68,68,.10); border-color: rgba(239,68,68,.30)}
.btn.warn{background: rgba(245,158,11,.10); border-color: rgba(245,158,11,.30)}
.btn.selected{
  box-shadow: 0 14px 34px rgba(0,0,0,.16);
  border-color: rgba(59,130,246,.55);
  outline: 2px solid rgba(59,130,246,.18);
  outline-offset: 2px;
}
.small{font-size:12px; color: var(--muted)}
.hr{height:1px; background: var(--stroke); margin:16px 0}

.form{
  display:grid; grid-template-columns: 1fr 1fr; gap:12px;
}
.field{display:flex; flex-direction:column; gap:8px}
.field label{font-size:12px; color: var(--muted)}
.input, textarea, select{
  width:100%;
  padding:12px 12px;
  border-radius: 16px;
  border:1px solid var(--stroke);
  background: rgba(255,255,255,.85);
  color: var(--text);
  outline:none;
}
.input:focus, textarea:focus, select:focus{
  border-color: rgba(96,165,250,.55);
  box-shadow: 0 0 0 4px rgba(96,165,250,.18);
}
textarea{min-height:110px; resize:vertical}
.full{grid-column: 1 / -1}

.table{
  width:100%;
  border-collapse: collapse;
  overflow:hidden;
  border-radius: 16px;
  border:1px solid var(--stroke);
  background: rgba(255,255,255,.85);
}
.table th, .table td{
  text-align:left;
  padding:12px 12px;
  border-bottom:1px solid var(--stroke);
  font-size:13px;
}
.table th{color: var(--muted); font-weight:800; background: rgba(15, 23, 42, .03)}
.table tr:hover td{background: rgba(15, 23, 42, .02)}

.badge{
  display:inline-flex; align-items:center; gap:6px;
  padding:6px 10px; border-radius: 999px;
  font-size:12px; border:1px solid var(--stroke);
  background: rgba(15, 23, 42, .03);
  color: var(--muted);
  font-weight:700;
}
.badge.ok{border-color: rgba(16,185,129,.30); background: rgba(16,185,129,.10); color: #047857}
.badge.bad{border-color: rgba(239,68,68,.30); background: rgba(239,68,68,.10); color: #b91c1c}
.badge.warn{border-color: rgba(245,158,11,.30); background: rgba(245,158,11,.10); color: #92400e}

.iconbtn{
  width:38px;height:38px; border-radius: 16px;
  display:inline-flex; align-items:center; justify-content:center;
  background: rgba(15, 23, 42, .03);
  border:1px solid var(--stroke);
  cursor:pointer;
}
.iconbtn:hover{background: rgba(15, 23, 42, .06)}
.flex{display:flex; gap:14px; align-items:center}
.space{justify-content:space-between}
.stack{display:flex; flex-direction:column; gap:12px}
.split{
  display:grid; grid-template-columns: 1fr 1fr; gap:18px;
}

.chat{
  border:1px solid var(--stroke);
  border-radius: var(--radius);
  background: rgba(255,255,255,.78);
  box-shadow: var(--shadow);
  overflow:hidden;
}
.chat .head{padding:14px 16px; border-bottom:1px solid var(--stroke); display:flex; align-items:center; justify-content:space-between; background: rgba(15, 23, 42, .02)}
.chat .msgs{padding:14px 16px; height:260px; overflow:auto; display:flex; flex-direction:column; gap:10px}
.bubble{
  max-width: 82%;
  padding:10px 12px;
  border-radius: 18px;
  border:1px solid var(--stroke);
  background: rgba(15, 23, 42, .02);
  font-size:13px;
  line-height:1.35;
}
.bubble.me{align-self:flex-end; background: rgba(45,212,191,.12); border-color: rgba(45,212,191,.25)}
.bubble.them{align-self:flex-start; background: rgba(96,165,250,.10); border-color: rgba(96,165,250,.22)}
.chat .send{
  display:flex; gap:10px;
  padding:14px 16px;
  border-top:1px solid var(--stroke);
  background: rgba(15, 23, 42, .01);
}

.footer{
  margin:22px 0 6px;
  text-align:center; color: var(--muted); font-size:12px;
}

@media (max-width: 880px){
  .hero{grid-template-columns:1fr}
  .grid{grid-template-columns:1fr}
  .form{grid-template-columns:1fr}
  .split{grid-template-columns:1fr}
  .nav{justify-content:flex-start}
}

.chip:hover{background: rgba(15,23,42,.06); border-color: rgba(96,165,250,.35)}

.thumb{width:56px;height:42px;object-fit:cover;border-radius:14px;border:1px solid var(--stroke);background:#fff;display:block}
.thumb-lg{width:100%;max-width:520px;height:240px;object-fit:cover;border-radius:18px;border:1px solid var(--stroke);background:#fff}
.previewbox{border:1px dashed rgba(96,165,250,.45);border-radius:18px;padding:12px;background:rgba(96,165,250,.06)}

/* Light green hover for all buttons (added as a separate block to keep original UI CSS unchanged) */
button:hover,
input[type="submit"]:hover,
input[type="button"]:hover,
a[class*="btn"]:hover,
button[class*="btn"]:hover,
input[class*="btn"]:hover {
  background-color: #90EE90 !important;
  border-color: #90EE90 !important;
}

/* Location input layout (non-invasive) */
.locrow{ display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
.locrow .input{ flex:1 1 280px; }
.locmini{ display:flex; gap:10px; flex-wrap:wrap; margin-top:10px; }
.locmini .input{ flex:1 1 140px; }

/* Stronger green hover across project buttons/links without changing default UI */
.btn:hover, .chip:hover, .iconbtn:hover, a.btn:hover{ 
  background-color:#90EE90 !important; 
  border-color:#90EE90 !important; 
}


/* Admin dashboard performance/compact layout */
.admin-lite-page .admin-stats-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;}
.admin-lite-page .admin-main-grid{align-items:start;}
.admin-lite-page .admin-table-wrap{overflow-x:auto;}
.admin-lite-page .admin-action-stack{gap:8px;}
.admin-lite-page .admin-heroart img{max-height:320px; object-fit:cover;}
.admin-lite-page .table{min-width:620px;}
@media (max-width: 1100px){.admin-lite-page .admin-stats-grid{grid-template-columns:repeat(3,1fr);}}
@media (max-width: 760px){.admin-lite-page .admin-stats-grid{grid-template-columns:repeat(2,1fr);} .admin-lite-page .admin-action-stack{flex-direction:column; align-items:stretch;} .admin-lite-page .table{min-width:560px;}}

/* Donor/Student dashboard refreshed layout */
.dashboard-page{max-width:1180px}
.slim-topbar{padding:12px 18px; border-radius:20px}
.dashboard-banner{
  margin-top:16px; border:1px solid var(--stroke); border-radius:24px; padding:18px;
  background:linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.82));
  box-shadow:var(--shadow);
}
.donor-theme{background:
  radial-gradient(500px 220px at 0% 100%, rgba(45,212,191,.18), transparent 60%),
  radial-gradient(420px 240px at 100% 0%, rgba(96,165,250,.14), transparent 55%),
  linear-gradient(180deg, rgba(255,255,255,.94), rgba(255,255,255,.82));}
.student-theme{background:
  radial-gradient(500px 220px at 0% 100%, rgba(45,212,191,.16), transparent 60%),
  radial-gradient(420px 240px at 100% 0%, rgba(167,139,250,.16), transparent 55%),
  linear-gradient(180deg, rgba(255,255,255,.94), rgba(255,255,255,.82));}
.banner-content{display:flex;justify-content:space-between;gap:18px;align-items:center;margin-bottom:16px}
.banner-content h2{margin:0;font-size:34px;line-height:1.1}
.banner-content p{margin:6px 0 0;color:var(--muted)}
.banner-actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.soft-pill{display:inline-flex;align-items:center;padding:9px 14px;border-radius:999px;background:rgba(15,23,42,.05);border:1px solid var(--stroke);font-weight:700}
.overview-grid{display:grid;grid-template-columns:1.35fr 1fr 1fr 1fr;gap:14px;align-items:stretch}
.mini-card{background:rgba(255,255,255,.88);border:1px solid var(--stroke);border-radius:20px;padding:14px;box-shadow:0 10px 28px rgba(15,23,42,.08)}
.mini-head{font-weight:800;font-size:14px;margin-bottom:10px}
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:12px}
.stats-row div{background:rgba(15,23,42,.03);border-radius:16px;padding:10px;text-align:center}
.stats-row strong{display:block;font-size:23px}
.stats-row span,.detail-stack span,.quick-metrics span{display:block;font-size:11px;color:var(--muted);margin-top:3px}
.mini-table{width:100%;border-collapse:collapse}
.mini-table th,.mini-table td{font-size:12px;padding:8px 6px;border-bottom:1px solid rgba(15,23,42,.08);text-align:left;vertical-align:top}
.detail-stack{display:grid;gap:10px}
.detail-stack div{padding:10px 12px;border-radius:16px;background:rgba(15,23,42,.03)}
.detail-stack strong{display:block;margin-top:5px;font-size:14px}
.empty-mini{padding:16px;border-radius:16px;background:rgba(15,23,42,.03);color:var(--muted)}
.chat-preview-list{display:grid;gap:10px;min-height:134px}
.chat-preview-item{padding:10px 12px;border-radius:16px;background:rgba(15,23,42,.03);display:flex;flex-direction:column;gap:4px;font-size:12px}
.preview-send-row{display:flex;gap:10px;margin-top:12px}
.preview-send-row .input{background:#fff}
.quick-metrics{display:grid;gap:12px}
.quick-metrics div{padding:12px;border-radius:16px;background:rgba(15,23,42,.03)}
.quick-metrics strong{display:block;font-size:22px;margin-top:6px}
.flash-strip{margin-top:14px;padding:12px 14px;border-radius:16px;border:1px solid var(--stroke);font-weight:700}
.error-strip{background:rgba(239,68,68,.08);border-color:rgba(239,68,68,.20);color:#991b1b}
.success-strip{background:rgba(16,185,129,.08);border-color:rgba(16,185,129,.20);color:#047857}
.section-gap{margin-top:18px}
.dashboard-two-col{display:grid;grid-template-columns:1fr 1fr;gap:18px;align-items:start}
.compact-form .input,.compact-form textarea,.compact-form select{border-radius:14px}
.form-card .body{padding-top:16px}
.list-card .body,.conversation-card .msgs{background:rgba(255,255,255,.9)}
.table-scroll{overflow-x:auto}
.tall-msgs{height:420px}
.meta-line{font-size:11px;color:var(--muted);margin-bottom:4px}
.bottom-align{align-items:stretch}
.auth-grid{margin-top:18px}

@media (max-width: 1120px){
  .overview-grid{grid-template-columns:1fr 1fr}
}
@media (max-width: 760px){
  .banner-content{flex-direction:column;align-items:flex-start}
  .overview-grid{grid-template-columns:1fr}
  .stats-row{grid-template-columns:repeat(2,1fr)}
  .dashboard-two-col{grid-template-columns:1fr}
}
