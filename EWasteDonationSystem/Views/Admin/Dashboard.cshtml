@* Documented for easier understanding. *@
@model EWasteDonationSystem.Models.AdminDashboardVm
@using System.Collections.Generic
@using EWasteDonationSystem.Models
@{
    ViewBag.Title = "Admin Dashboard";
    var adminVm = Model ?? new AdminDashboardVm();
    var donationItemsSafe = adminVm.DonationItems ?? new List<DonationItem>();
    var studentApplicationsSafe = adminVm.StudentApplications ?? new List<StudentApplication>();
    var donorItemsLookup = donationItemsSafe
        .Where(i => i.DonorId > 0)
        .GroupBy(i => i.DonorId)
        .ToDictionary(g => g.Key, g => g.FirstOrDefault());
    var studentAppsLookup = studentApplicationsSafe
        .Where(a => a.StudentId > 0)
        .GroupBy(a => a.StudentId)
        .ToDictionary(g => g.Key, g => g.FirstOrDefault());
    var adminEmail = Session["AdminEmail"] as string ?? "";

    var isAdminLoggedIn = Session["AdminLoggedIn"];
}

<div class="container admin-lite-page">
    <div class="topbar">
        <div class="brand">
            <div class="logo"><img src="@Url.Content("~/Content/images/AdminLogo.jpeg")" alt="Logo" loading="lazy" /></div>
            <div>
                <h1>Admin Dashboard</h1>
                <p>Fast loading view for approve/reject, pickup team and admin chat preview.</p>
            </div>
        </div>
        <div class="nav">
            <span style="color: #666; margin-right: 16px;">Email: <strong>@adminEmail</strong></span>
            <a class="chip" href="@Url.Action("Index", "Home")">Home</a>
            <a class="chip" href="@Url.Action("Logout", "Account", new { role = "admin" })">Logout</a>
        </div>
    </div>

    <div class="hero admin-lite-hero" style="margin-top:18px; align-items:center;">
        <div>
            <h2>Admin Control Panel</h2>
            <p>
                This page is adjusted to open faster. It shows recent donors and students first,
                while keeping the same admin dashboard style from your screenshots.
            </p>
            <div class="hr"></div>
            <div class="btnrow">
                <a class="btn ghost" href="@Url.Action("Dashboard", "Donor")">Open Donor Page</a>
                <a class="btn ghost" href="@Url.Action("Dashboard", "Student")">Open Students Page</a>
                <a class="btn primary" href="@Url.Action("Dashboard", "Admin")">Refresh Data</a>
            </div>
        </div>
        <div class="heroart admin-heroart">
            <img src="@Url.Content("~/Content/images/AdminBanner.jpeg")" alt="Admin Banner" loading="lazy" />
        </div>
    </div>

    <div class="admin-stats-grid" style="margin-top:18px;">
        <div class="kpi"><div class="label">Total Donors</div><div class="value">@adminVm.TotalDonors</div></div>
        <div class="kpi"><div class="label">Total Students</div><div class="value">@adminVm.TotalStudents</div></div>
        <div class="kpi"><div class="label">Pending Donors</div><div class="value">@adminVm.PendingDonors</div></div>
        <div class="kpi"><div class="label">Pending Students</div><div class="value">@adminVm.PendingStudents</div></div>
        <div class="kpi"><div class="label">Pickup Assignments</div><div class="value">@adminVm.TotalPickupAssignments</div></div>
    </div>

    <div class="admin-horizontal-grid admin-main-layout" style="margin-top:18px;">
        <div class="card">
            <div class="head">
                <h3>Donors List (Approve/Reject)</h3>
                <p>Showing Detail oF @adminVm.RecentDonorCount Donors .</p>
            </div>
            <div class="body admin-table-wrap admin-form-space">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Donor</th>
                            <th>Item</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Actions</th>
                            <th>Detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!adminVm.Donors.Any())
                        {
                            <tr><td colspan="5">No donors found yet.</td></tr>
                        }
                        else
                        {
                            foreach (var d in adminVm.DonationItems)
                            {
                                //var item = donorItemsLookup.ContainsKey(d.Id) ? donorItemsLookup[d.Id] : null;
                                var badgeClass = d.Status == ApprovalStatus.Approved ? "badge ok" : d.Status == ApprovalStatus.Rejected ? "badge bad" : "badge warn";
                    <tr>
                        <td>
                            <strong>@d.Donor.FullName</strong><br />
                            <span class="small">DNR-@d.Id.ToString("000000")</span><br />
                            <span class="small">@(string.IsNullOrWhiteSpace(d.Donor.City) ? d.Donor.Email : d.Donor.City)</span>
                        </td>
                        <td>@(d != null ? d.ItemName + " (x" + d.Quantity + ")" : "—")</td>
                        <td><span>@d.Price</span></td>

                        <td><span class="@badgeClass">@d.Status</span></td>
                        <td>
                            <div class="btnrow admin-action-stack">
                                <button type="button"
                                        class="btn ok"
                                        onclick="openDonorApproveModal(this)"
                                        data-item-id="@d.Id"
                                        data-item-name="@(d.ItemName ?? "")"
                                        data-cost-price="@d.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                        data-sale-price="@(d.SalePrice > 0 ? d.SalePrice.ToString(System.Globalization.CultureInfo.InvariantCulture) : "")">
                                    Approve
                                </button>
                                @using (Html.BeginForm("SetDonorStatus", "Admin", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@d.Id" />
                                    <input type="hidden" name="status" value="Rejected" />
                                    <button class="btn warn" type="submit">Reject</button>
                                }
                                @*@using (Html.BeginForm("SetDonorStatus", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@d.Id" />
                    <input type="hidden" name="status" value="Pending" />
                    <button class="btn ghost" type="submit">Pending</button>
                }*@
                            </div>
                        </td>
                        <td><a class="iconbtn detail-eye-btn" title="Open item detail" href="@Url.Action("DonorDetail", "Admin", new { id = d.Id })">&#128065;</a></td>
                    </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="head">
                <h3>Students/Needy List (Approve/Reject)</h3>
                <p>Showing Detail of @adminVm.RecentStudentCount students.</p>
            </div>
            <div class="body admin-table-wrap admin-form-space">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Applicant</th>
                            <th>Needed</th>
                            <th>Status</th>
                            <th>Actions</th>
                            <th>Detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!adminVm.Students.Any())
                        {
                            <tr><td colspan="5">No students found yet.</td></tr>
                        }
                        else
                        {
                            foreach (var s in adminVm.StudentApplications)
                            {
                                //var app = studentAppsLookup.ContainsKey(s.Id) ? studentAppsLookup[s.Id] : null;
                                var badgeClass = s.Status == ApprovalStatus.Approved ? "badge ok" : s.Status == ApprovalStatus.Rejected ? "badge bad" : "badge warn";
                                <tr>
                                    <td>
                                        <strong>@s.Student.FullName</strong><br />
                                        <span class="small">STD-@s.Id.ToString("000000")</span><br />
                                        <span class="small">@(string.IsNullOrWhiteSpace(s.Student.City) ? s.Student.Email : s.Student.City)</span>
                                    </td>
                                    <td>@(s != null ? s.ItemsNeeded : "—")</td>
                                    <td><span class="@badgeClass">@s.Status</span></td>
                                    <td>
                                        <div class="btnrow admin-action-stack">
                                            @using (Html.BeginForm("SetStudentStatus", "Admin", FormMethod.Post))
                                            {
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@s.Id" />
                                                <input type="hidden" name="status" value="Approved" />
                                                <button class="btn ok" type="submit">Approve</button>
                                            }
                                            @using (Html.BeginForm("SetStudentStatus", "Admin", FormMethod.Post))
                                            {
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@s.Id" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <button class="btn warn" type="submit">Reject</button>
                                            }
                                            @*@using (Html.BeginForm("SetStudentStatus", "Admin", FormMethod.Post))
                                            {
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@s.Id" />
                                                <input type="hidden" name="status" value="Pending" />
                                                <button class="btn ghost" type="submit">Pending</button>
                                            }*@
                                        </div>
                                    </td>
                                    <td><a class="iconbtn detail-eye-btn" title="Open Student Detail" href="@Url.Action("StudentDetail", "Admin", new { id = s.Student.Id })">&#128065;</a></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    
        <div class="card admin-vertical-card admin-full-span">
            <div class="head">
                <h3>Pickup Agent Team</h3>
                <p>Same admin section with a lighter and cleaner layout.</p>
            </div>
            <div class="body admin-form-space">
                @using (Html.BeginForm("AddPickupAgent", "Admin", FormMethod.Post, new { data_ajax_form = "true" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="form admin-single-column-form">
                        <div class="field"><label>Agent Name / Team</label><input class="input" name="agentName" placeholder="e,g., Sultan Ali" /></div>
                        <div class="field"><label>Phone</label><input class="input" name="phone" placeholder="+92 346 2323368" /></div>
                        <div class="field full"><label>Area / City</label><input class="input" name="area" placeholder="e.g., Dera Ismail Khan" /></div>
                        <div class="field full"><label>Email</label><input class="input" type="email" name="email" placeholder="agent@gmail.com" /></div>
                    </div>
                    <div class="hr"></div>
                    <button class="btn primary" type="submit">Add Agent</button>
                }
                <div class="hr"></div>
                <table class="table">
                    <thead><tr><th>Agent</th><th>Phone</th><th>Area</th><th>Email</th></tr></thead>
                    <tbody>
                        @foreach (var agent in adminVm.PickupAgents)
                        {
                            <tr>
                                <td><strong>@agent.AgentName</strong><br /><span class="small">@agent.AgentCode</span></td>
                                <td>@agent.Phone</td>
                                <td>@agent.Area</td>
                                <td>@agent.Email</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card admin-vertical-card admin-full-span">
            <div class="head">
                <h3>Assign Pickup Agent (Admin)</h3>
                <p>Quick assignment area kept in the same style as your images.</p>
            </div>
            <div class="body admin-form-space">
                @using (Html.BeginForm("AssignPickupAgent", "Admin", FormMethod.Post, new { data_ajax_form = "true" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="form admin-single-column-form">
                        <div class="field full">
                            <label>Donor</label>
                            <select class="input" name="donorId">
                                <option value="">Select Donor</option>
                                @if (adminVm.Donors.Any())
                                {
                                    foreach (var donor in adminVm.Donors)
                                    {
                                        <option value="@donor.Id" @(adminVm.SelectedDonorId == donor.Id.ToString() ? "selected" : "")>@donor.FullName (DNR-@donor.Id.ToString("000000"))</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="field full">
                            <label>Pickup Agent</label>
                            <select class="input" name="agentCode">
                                <option value="">Select Pickup Agent</option>
                                @foreach (var agent in adminVm.PickupAgents)
                                {
                                    <option value="@agent.AgentCode" @(adminVm.SelectedAgentCode == agent.AgentCode ? "selected" : "")>@agent.AgentName (@agent.Area)</option>
                                }
                            </select>
                        </div>
                        <div class="field full">
                            <label>Location</label>
                            <input class="input" name="location" placeholder="Enter pickup location address" />
                        </div>
                    </div>
                    <div class="hr"></div>
                    <div class="btnrow">
                        <button class="btn primary" type="submit">Assign</button>
                    </div>
                }
                <div class="hr"></div>
                <table class="table">
                    <thead><tr><th>Donor</th><th>Pickup Agent</th><th>Location</th><th>Assigned At</th></tr></thead>
                    <tbody>
                        @if (!adminVm.PickupAssignments.Any())
                        {
                            <tr><td colspan="4">No pickup assignments yet.</td></tr>
                        }
                        else
                        {
                            foreach (var assignment in adminVm.PickupAssignments)
                            {
                                <tr>
                                    <td>@assignment.DonorName</td>
                                    <td>@assignment.AgentName</td>
                                    <td>@assignment.Location</td>
                                    <td>@assignment.AssignedAtUtc.ToLocalTime().ToString("g")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="chat admin-chat-wrap" style="margin-top:28px;">
        <div class="head">
            <div class="flex"><span class="badge">Admin Chat</span><span class="small">Working admin chat with donor and student selection</span></div>
        </div>
        <div class="body admin-form-space" style="padding:22px;">
            @using (Html.BeginForm("Dashboard", "Admin", FormMethod.Get, new { id = "adminChatFilterForm" }))
            {
                <div class="form admin-chat-form-space">
                    <div class="field full">
                        <label>Chat Target</label>
                        <select class="input" name="chatTarget" onchange="document.getElementById('adminChatPersonId').value=''; document.getElementById('adminChatFilterForm').submit();">
                            <option value="Donor" @(adminVm.SelectedChatTarget == "Donor" ? "selected" : "")>Donor</option>
                            <option value="Student" @(adminVm.SelectedChatTarget == "Student" ? "selected" : "")>Student</option>
                        </select>
                    </div>
                    <div class="field full">
                        <label>Select Person</label>
                        <select class="input" id="adminChatPersonId" name="chatPersonId" onchange="document.getElementById('adminChatFilterForm').submit();">
                            <option value="">Select Person</option>
                            @if (adminVm.SelectedChatTarget == "Student")
                            {
                                foreach (var student in adminVm.Students)
                                {
                                    <option value="@student.Id" @(adminVm.SelectedChatPersonId == student.Id.ToString() ? "selected" : "")>@student.FullName (@student.Status.ToString().ToLower())</option>
                                }
                            }
                            else
                            {
                                foreach (var donor in adminVm.Donors)
                                {
                                    <option value="@donor.Id" @(adminVm.SelectedChatPersonId == donor.Id.ToString() ? "selected" : "")>@donor.FullName (@donor.Status.ToString().ToLower())</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            }

            <div class="chat" style="margin-top:18px; box-shadow:none; background:rgba(15,23,42,.015);">
                <div class="msgs admin-chat-messages">
                    @if (!adminVm.PreviewMessages.Any())
                    {
                        <div class="bubble them">No messages yet.</div>
                    }
                    else
                    {
                        foreach (var msg in adminVm.PreviewMessages)
                        {
                            var isMine = msg.SenderRole == "Admin";
                            var cls = isMine ? "bubble me" : "bubble them";
                            <div class="@cls">
                                <div>@msg.Message</div>
                                <div class="small" style="margin-top:4px;">@msg.SenderRole • @msg.SentAtUtc.ToLocalTime().ToString("g")</div>
                                <div class="chat-delete-actions">
                                    @using (Html.BeginForm("DeleteDashboardMessageForMe", "Admin", FormMethod.Post, new { @class = "inline-delete-form" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="chatTarget" value="@adminVm.SelectedChatTarget" />
                                        <input type="hidden" name="chatPersonId" value="@adminVm.SelectedChatPersonId" />
                                        <input type="hidden" name="messageId" value="@msg.Id" />
                                        <button type="submit" class="chat-delete-btn">Delete for me</button>
                                    }
                                    @if (isMine)
                                    {
                                        using (Html.BeginForm("DeleteDashboardMessageForEveryone", "Admin", FormMethod.Post, new { @class = "inline-delete-form" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="chatTarget" value="@adminVm.SelectedChatTarget" />
                                            <input type="hidden" name="chatPersonId" value="@adminVm.SelectedChatPersonId" />
                                            <input type="hidden" name="messageId" value="@msg.Id" />
                                            <button type="submit" class="chat-delete-btn delete-everyone">Delete for everyone</button>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
                @using (Html.BeginForm("SendDashboardMessage", "Admin", FormMethod.Post, new { data_ajax_form = "true" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="chatTarget" value="@adminVm.SelectedChatTarget" />
                    <input type="hidden" name="chatPersonId" value="@adminVm.SelectedChatPersonId" />
                    <div class="send admin-chat-sendbar">
                        <input class="input" name="message" placeholder="Type admin message..." />
                        <button class="btn primary" type="submit">Send</button>
                    </div>
                }
            </div>
        </div>
    </div>

<div id="donorApproveModal" class="otp-modal">
    <div class="otp-backdrop" onclick="closeDonorApproveModal()"></div>
    <div class="otp-content">
        <button type="button" class="otp-close" onclick="closeDonorApproveModal()">&times;</button>
        <h3>Approve Donation Item</h3>
        <p class="small">Item: <strong id="approveModalItemName"></strong></p>
        @using (Html.BeginForm("SetDonorStatus", "Admin", FormMethod.Post, new { id = "donorApproveForm" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="approveModalItemId" value="" />
            <input type="hidden" name="status" value="Approved" />
            <div class="form admin-single-column-form" style="margin-top:14px;">
                <div class="field full">
                    <label for="approveModalCostPrice">Cost Price</label>
                    <input type="text" id="approveModalCostPrice" class="input" disabled />
                </div>
                <div class="field full">
                    <label for="approveModalSalePrice">Sale Price</label>
                    <input type="number" class="input" id="approveModalSalePrice" name="salePrice" step="0.01" min="1" required placeholder="Enter sale price" />
                </div>
            </div>
            <div class="btnrow" style="margin-top:18px;">
                <button class="btn ok" type="submit">Approve</button>
                <button class="btn ghost" type="button" onclick="closeDonorApproveModal()">Close</button>
            </div>
        }
    </div>
</div>

<script>
    function openDonorApproveModal(button) {
        var modal = document.getElementById('donorApproveModal');
        if (!modal || !button) return;

        var itemId = document.getElementById('approveModalItemId');
        var itemName = document.getElementById('approveModalItemName');
        var costPrice = document.getElementById('approveModalCostPrice');
        var salePrice = document.getElementById('approveModalSalePrice');

        if (itemId) itemId.value = button.getAttribute('data-item-id') || '';
        if (itemName) itemName.textContent = button.getAttribute('data-item-name') || '';
        if (costPrice) costPrice.value = button.getAttribute('data-cost-price') || '';
        if (salePrice) {
            salePrice.value = button.getAttribute('data-sale-price') || '';
            salePrice.focus();
        }

        modal.classList.add('active');
    }

    function closeDonorApproveModal() {
        var modal = document.getElementById('donorApproveModal');
        if (!modal) return;
        modal.classList.remove('active');

        var approveForm = document.getElementById('donorApproveForm');
        var costPrice = document.getElementById('approveModalCostPrice');
        if (approveForm) approveForm.reset();
        if (costPrice) costPrice.value = '';
    }

    document.addEventListener('keydown', function (ev) {
        if (ev.key === 'Escape') closeDonorApproveModal();
    });

(function(){
    function wireAjaxForms(){
        var forms = document.querySelectorAll('form[data-ajax-form="true"]');
        forms.forEach(function(form){
            if(form.dataset.ajaxBound === 'true') return;
            form.dataset.ajaxBound = 'true';

            form.addEventListener('submit', function(ev){
                ev.preventDefault();
                var submitter = document.activeElement && document.activeElement.form === form ? document.activeElement : null;
                var formData = new FormData(form);
                if(submitter && submitter.name){ formData.append(submitter.name, submitter.value || ''); }

                fetch(form.action, {
                    method: form.method || 'POST',
                    body: formData,
                    credentials: 'same-origin',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(function(res){ return res.text(); })
                .then(function(html){
                    document.open();
                    document.write(html);
                    document.close();
                })
                .catch(function(){ form.submit(); });
            });
        });
    }

    if(document.readyState === 'loading'){
        document.addEventListener('DOMContentLoaded', wireAjaxForms);
    } else {
        wireAjaxForms();
    }
})();
</script>

<style>
    .otp-modal {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .otp-modal.active {
        display: flex;
    }

    .otp-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
    }

    .otp-content {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 24px 70px rgba(15, 23, 42, 0.2);
        padding: 28px 26px;
    }

    .otp-close {
        position: absolute;
        top: 14px;
        right: 14px;
        border: none;
        background: transparent;
        font-size: 24px;
        cursor: pointer;
        color: #334155;
    }

    .otp-content h3 {
        margin-top: 0;
    }

    .otp-content .small {
        color: #64748b;
    }

    .admin-chat-wrap .chat-delete-actions{display:flex; gap:8px; flex-wrap:wrap; margin-top:8px;}
    .admin-chat-wrap .inline-delete-form{display:inline-block; margin:0;}
    .admin-chat-wrap .chat-delete-btn{background:none; border:none; padding:0; font-size:12px; cursor:pointer; text-decoration:underline; opacity:.85;}
    .admin-chat-wrap .delete-everyone{font-weight:700;}
</style>

    <div class="footer">Admin UI — adjusted for quicker loading and cleaner dashboard display.</div>
</div>
