@* Documented for easier understanding. *@
@model EWasteDonationSystem.Models.ChooseRoleViewModel
@{
    // Choose Role page title shown in the browser tab.
    ViewBag.Title = "Choose Role | E-Waste Pickup and Donations system";

    // Current role and mode are used to highlight the correct card/tab on page load.
    var selectedRole = (Model.SelectedRole ?? "donor").ToLower();
    var mode = (Model.Mode ?? "login").ToLower();
}



@* Choose Role page wrapper. Styling is now moved to Content/assets/style.css. *@
<div class="container role-page-wrap">
        @* Main authentication card. *@
    <div class="role-auth-shell">
        <a class="top-home-link" href="@Url.Action("Index", "Home")">Back to Home</a>

        <div class="role-auth-header">
            <h1>Choose Your Roles And Get Started</h1>
            <p>Select a role, then use login or sign up to continue.</p>
        </div>

                @* Role selection cards. *@
        <div class="role-card-row">
            <button type="button" class="role-option-card @(selectedRole == "donor" ? "active" : "")" data-role="donor">
                <div class="role-option-icon" aria-hidden="true">
                    <img src="@Url.Content("~/Content/images/DonorLogo.jpeg")" alt="Donor" />
                </div>
                <div class="role-option-title">Donor</div>
                <p class="role-option-text">Donate your e-waste responsibly</p>
            </button>

            <button type="button" class="role-option-card @(selectedRole == "admin" ? "active" : "")" data-role="admin">
                <div class="role-option-icon" aria-hidden="true">
                    <img src="@Url.Content("~/Content/images/AdminLogo.jpeg")" alt="Admin" />
                </div>
                <div class="role-option-title">NGO / Admin</div>
                <p class="role-option-text">Manage donations and pickups</p>
            </button>

            <button type="button" class="role-option-card @(selectedRole == "student" ? "active" : "")" data-role="student">
                <div class="role-option-icon" aria-hidden="true">
                    <img src="@Url.Content("~/Content/images/StudentLogo.jpeg")" alt="Student" />
                </div>
                <div class="role-option-title">Student / Needy Person</div>
                <p class="role-option-text">Receive refurbished electronics</p>
            </button>
        </div>

                @* Login / Sign Up switch. *@
        <div class="auth-toggle">
            <button type="button" id="loginTab" class="auth-tab @(mode == "login" ? "active" : "")">Login</button>
            <button type="button" id="signupTab" class="auth-tab @(mode == "signup" ? "active" : "")">Sign Up</button>
        </div>

        <div class="role-form-shell">
            <div id="donorLoginPanel" class="role-panel">
                @using (Html.BeginForm("DonorLogin", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="role-form-grid single">
                        <div class="role-field">
                            <label>Email</label>
                            <input type="email" name="email" placeholder="Enter your email" required />
                        </div>
                        <div class="role-field">
                            <label>Password</label>
                            <input type="password" name="password" placeholder="Enter your password" required />
                        </div>
                    </div>
                    <div class="role-actions">
                        <button class="role-submit" type="submit">Login as Donor</button>
                    </div>
                }
                <div class="forgot-wrap">
                    <button type="button" class="forgot-link" data-forgot-target="donorForgotPanel">Forgotten Password?</button>
                </div>
                <div id="donorForgotPanel" class="forgot-panel">
                    <h3 class="forgot-title">Recover donor password</h3>
                    <p class="forgot-note">Enter your donor email, request an OTP, then set a new password.</p>
                    @using (Html.BeginForm("DonorForgotPassword", "Account", FormMethod.Post, new { id = "donorForgotForm" }))
                    {
                        @Html.AntiForgeryToken()
                <div class="role-form-grid">
                    <div class="role-field">
                        <label>Email</label>
                        <input type="email" id="donorForgotEmail" name="email" placeholder="Enter donor email" required />
                    </div>
                    <div class="role-field">
                        <label>Send OTP</label>
                        <button class="role-submit" type="button" id="donorSendOtpBtn">Send OTP</button>
                    </div>
                    <div class="role-field" style="grid-column:1 / -1;">
                        <div id="donorOtpStatus" class="otp-status" aria-live="polite"></div>
                    </div>
                    <div class="role-field">
                        <label>OTP</label>
                        <input type="text" name="otp" placeholder="Enter otp" required maxlength="6" inputmode="numeric" autocomplete="one-time-code" />
                    </div>
                    <div class="role-field">
                        <label>New Password</label>
                        <input type="password" name="newPassword" placeholder="Enter new password" required pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}" title="Use 8+ chars with uppercase, lowercase, number and special character." />
                    </div>
                    <div class="role-field" style="grid-column:1 / -1;">
                        <label>Confirm New Password</label>
                        <input type="password" name="confirmPassword" placeholder="Confirm new password" required />
                    </div>
                </div>
                        <div class="role-actions">
                            <button class="role-submit" type="submit">Recover Donor Password</button>
                        </div>
                    }
                </div>
            </div>

            <div id="donorSignupPanel" class="role-panel">
                @using (Html.BeginForm("DonorSignUp", "Account", FormMethod.Post, new { @class = "client-validate-form" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="role-form-grid">
                        <div class="role-field">
                            <label>User Name</label>
                            <input type="text" name="userName" placeholder="Choose a username" required data-label="User Name" />
                        </div>
                        <div class="role-field">
                            <label>Name</label>
                            <input type="text" name="name" placeholder="Enter your full name" required data-label="Name" />
                        </div>
                        <div class="role-field">
                            <label>Email</label>
                            <input type="email" name="email" placeholder="Enter your email" required data-label="Email" />
                        </div>
                        <div class="role-field">
                            <label>Password</label>
                            <input type="password" name="password" placeholder="Create password" required data-label="Password" pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}" title="Use 8+ chars with uppercase, lowercase, number and special character." />
                        </div>
                        <div class="role-field" style="grid-column:1 / -1;">
                            <label>Confirm Password</label>
                            <input type="password" name="confirmPassword" placeholder="Re-enter password" required data-label="Confirm Password" pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}" title="Use 8+ chars with uppercase, lowercase, number and special character." />
                        </div>
                    </div>
                    <div class="role-actions">
                        <button class="role-submit" type="submit">Sign Up as Donor</button>
                    </div>
                }
            </div>

            <div id="studentLoginPanel" class="role-panel">
                @using (Html.BeginForm("StudentLogin", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="role-form-grid single">
                        <div class="role-field">
                            <label>Email</label>
                            <input type="email" name="email" placeholder="Enter your email" required />
                        </div>
                        <div class="role-field">
                            <label>Password</label>
                            <input type="password" name="password" placeholder="Enter your password" required />
                        </div>
                    </div>
                    <div class="role-actions">
                        <button class="role-submit" type="submit">Login as Student / Needy Person</button>
                    </div>
                }
                <div class="forgot-wrap">
                    <button type="button" class="forgot-link" data-forgot-target="studentForgotPanel">Forgotten Password?</button>
                </div>
                <div id="studentForgotPanel" class="forgot-panel">
                    <h3 class="forgot-title">Recover student / needy person password</h3>
                    <p class="forgot-note">Enter your email, request an OTP, then set a new password.</p>
                    @using (Html.BeginForm("StudentForgotPassword", "Account", FormMethod.Post, new { id = "studentForgotForm" }))
                    {
                        @Html.AntiForgeryToken()
                        <div class="role-form-grid">
                            <div class="role-field">
                                <label>Email</label>
                                <input type="email" id="studentForgotEmail" name="email" placeholder="Enter your email" required />
                            </div>
                            <div class="role-field">
                                <label>Send OTP</label>
                                <button class="role-submit" type="button" id="studentSendOtpBtn">Send OTP</button>
                            </div>
                            <div class="role-field" style="grid-column:1 / -1;">
                                <div id="studentOtpStatus" class="otp-status" aria-live="polite"></div>
                            </div>
                            <div class="role-field">
                                <label>OTP</label>
                                <input type="text" name="otp" placeholder="Enter otp" required maxlength="6" inputmode="numeric" autocomplete="one-time-code" />
                            </div>
                            <div class="role-field">
                                <label>New Password</label>
                                <input type="password" name="newPassword" placeholder="Enter new password" required pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}" title="Use 8+ chars with uppercase, lowercase, number and special character." />
                            </div>
                            <div class="role-field" style="grid-column:1 / -1;">
                                <label>Confirm New Password</label>
                                <input type="password" name="confirmPassword" placeholder="Confirm new password" required />
                            </div>
                        </div>
                        <div class="role-actions">
                            <button class="role-submit" type="submit">Recover Student Password</button>
                        </div>
                    }
                </div>
            </div>

            <div id="studentSignupPanel" class="role-panel">
                @using (Html.BeginForm("StudentSignUp", "Account", FormMethod.Post, new { @class = "client-validate-form" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="role-form-grid">
                        <div class="role-field">
                            <label>User Name</label>
                            <input type="text" name="userName" placeholder="Choose a username" required data-label="User Name" />
                        </div>
                        <div class="role-field">
                            <label>Name</label>
                            <input type="text" name="name" placeholder="Enter your full name" required data-label="Name" />
                        </div>
                        <div class="role-field">
                            <label>Email</label>
                            <input type="email" name="email" placeholder="Enter your email" required data-label="Email" />
                        </div>
                        <div class="role-field">
                            <label>Password</label>
                            <input type="password" name="password" placeholder="Create password" required data-label="Password" pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}" title="Use 8+ chars with uppercase, lowercase, number and special character." />
                        </div>
                        <div class="role-field" style="grid-column:1 / -1;">
                            <label>Confirm Password</label>
                            <input type="password" name="confirmPassword" placeholder="Re-enter password" required data-label="Confirm Password" pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}" title="Use 8+ chars with uppercase, lowercase, number and special character." />
                        </div>
                    </div>
                    <div class="role-actions">
                        <button class="role-submit" type="submit">Sign Up as Student / Needy Person</button>
                    </div>
                }
            </div>

            <div id="adminLoginPanel" class="role-panel">
                @using (Html.BeginForm("AdminLogin", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <div class="role-form-grid single">
                        <div class="role-field">
                            <label>Gmail Account</label>
                            <input type="email" id="adminEmailInput" name="email" placeholder="Enter admin Gmail account" required />
                        </div>
                        <div class="role-field">
                            <label>Password</label>
                            <input type="password" id="adminPasswordInput" name="password" placeholder="Enter your password" required />
                        </div>
                    </div>
                    <div class="role-actions">
                        <button class="role-submit" type="submit">Login as NGO / Admin</button>
                    </div>
                }
                <div class="forgot-wrap">
                    <button type="button" class="forgot-link" data-forgot-target="adminForgotPanel">Forgotten Password?</button>
                </div>
                <div id="adminForgotPanel" class="forgot-panel">
                    <h3 class="forgot-title">Recover admin password</h3>
                    <p class="forgot-note">Use the admin Gmail account to recover the password for the admin role.</p>
                    @using (Html.BeginForm("AdminForgotPassword", "Account", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="role-form-grid">
                            <div class="role-field">
                                <label>Admin Gmail Account</label>
                                <input type="email" name="email" placeholder="Enter admin Gmail account" required />
                            </div>
                            <div class="role-field">
                                <label>New Password</label>
                            <input type="password" name="newPassword" placeholder="Enter new password" required pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}" title="Use 8+ chars with uppercase, lowercase, number and special character." />
                            </div>
                            <div class="role-field" style="grid-column:1 / -1;">
                                <label>Confirm New Password</label>
                                <input type="password" name="confirmPassword" placeholder="Confirm new password" required />
                            </div>
                        </div>
                        <div class="role-actions">
                            <button class="role-submit" type="submit">Recover Admin Password</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div id="otpModal" class="otp-modal">
    <div class="otp-backdrop" onclick="closeOtpDialog()"></div>
    <div class="otp-content">
        <button type="button" class="otp-close" onclick="closeOtpDialog()">×</button>
        <h3>Verify your email</h3>
        <p>An OTP has been sent to <strong id="otpEmailDisplay">@Html.Encode(ViewBag.OtpEmail ?? string.Empty)</strong>. Enter it below to activate your account.</p>
        @using (Html.BeginForm("VerifyDonorOtp", "Account", FormMethod.Post, new { @class = "otp-verify-form", id = "otpVerifyForm" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" id="otpEmailInput" name="email" value="@Html.Encode(ViewBag.OtpEmail ?? string.Empty)" />
            <div class="role-field">
                <label>OTP Code</label>
                <input type="text" name="otp" placeholder="Enter OTP" required />
            </div>
            <div class="role-actions">
                <button class="role-submit" type="submit">Verify OTP</button>
            </div>
        }
    </div>
</div>

<script>
    var selectedRole = '@selectedRole';
    var currentMode = '@mode';
    var showOtpDialog = @((ViewBag.ShowOtpDialog ?? false).ToString().ToLower());
    var otpEmail = '@System.Web.HttpUtility.JavaScriptStringEncode(ViewBag.OtpEmail ?? string.Empty)';
    var otpRole = '@System.Web.HttpUtility.JavaScriptStringEncode((ViewBag.OtpRole ?? "donor").ToString())';
    var verifyDonorOtpUrl = '@Url.Action("VerifyDonorOtp", "Account")';
    var verifyStudentOtpUrl = '@Url.Action("VerifyStudentOtp", "Account")';

    function closeForgotPanels() {
        document.querySelectorAll('.forgot-panel').forEach(function (panel) {
            panel.classList.remove('active');
        });
    }

    function openOtpDialog() {
        var modal = document.getElementById('otpModal');
        if (!modal) return;
        modal.classList.add('active');
        var emailDisplay = document.getElementById('otpEmailDisplay');
        if (emailDisplay) {
            emailDisplay.textContent = otpEmail || 'your email';
        }
        var verifyForm = document.getElementById('otpVerifyForm');
        if (verifyForm) {
            verifyForm.action = otpRole === 'student' ? verifyStudentOtpUrl : verifyDonorOtpUrl;
        }
        var emailInput = document.getElementById('otpEmailInput');
        if (emailInput && otpEmail) {
            emailInput.value = otpEmail;
        }
    }

    function closeOtpDialog() {
        var modal = document.getElementById('otpModal');
        if (!modal) return;
        modal.classList.remove('active');
    }

    function setRole(role) {
        selectedRole = role;
        if (selectedRole === 'admin') {
            currentMode = 'login';
        }
        closeForgotPanels();
        renderRoleUI();
    }

    function setMode(mode) {
        if (selectedRole === 'admin' && mode === 'signup') {
            currentMode = 'login';
        } else {
            currentMode = mode;
        }
        closeForgotPanels();
        renderRoleUI();
    }

    function renderRoleUI() {
        document.querySelectorAll('.role-option-card').forEach(function (card) {
            card.classList.toggle('active', card.getAttribute('data-role') === selectedRole);
        });

        var loginTab = document.getElementById('loginTab');
        var signupTab = document.getElementById('signupTab');
        loginTab.classList.toggle('active', currentMode === 'login');
        signupTab.classList.toggle('active', currentMode === 'signup');

        if (selectedRole === 'admin') {
            signupTab.disabled = true;
            signupTab.style.opacity = '0.55';
            signupTab.style.cursor = 'not-allowed';
        } else {
            signupTab.disabled = false;
            signupTab.style.opacity = '1';
            signupTab.style.cursor = 'pointer';
        }

        document.querySelectorAll('.role-panel').forEach(function (panel) {
            panel.classList.remove('active');
        });

        if (selectedRole === 'donor') {
            document.getElementById(currentMode === 'signup' ? 'donorSignupPanel' : 'donorLoginPanel').classList.add('active');
        } else if (selectedRole === 'student') {
            document.getElementById(currentMode === 'signup' ? 'studentSignupPanel' : 'studentLoginPanel').classList.add('active');
        } else {
            document.getElementById('adminLoginPanel').classList.add('active');
        }
    }

    document.querySelectorAll('.role-option-card').forEach(function (card) {
        card.addEventListener('click', function () {
            setRole(this.getAttribute('data-role'));
        });
    });

    document.getElementById('loginTab').addEventListener('click', function () {
        setMode('login');
    });

    document.getElementById('signupTab').addEventListener('click', function () {
        setMode('signup');
    });

    document.querySelectorAll('.forgot-link').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var targetId = this.getAttribute('data-forgot-target');
            var target = document.getElementById(targetId);
            var shouldOpen = target && !target.classList.contains('active');
            closeForgotPanels();
            if (shouldOpen) {
                target.classList.add('active');
            }
        });
    });

    function setupPasswordResetOtp(config) {
        var btn = document.getElementById(config.buttonId);
        if (!btn) return;

        btn.addEventListener('click', function () {
            var form = document.getElementById(config.formId);
            var emailInput = document.getElementById(config.emailInputId);
            var statusEl = document.getElementById(config.statusId);
            var email = (emailInput && emailInput.value || '').trim();

            if (statusEl) {
                statusEl.textContent = '';
                statusEl.className = 'otp-status';
            }

            if (!email) {
                showFieldError(emailInput, config.emailRequiredMessage);
                return;
            }

            clearFieldError(emailInput);

            var tokenInput = form ? form.querySelector('input[name="__RequestVerificationToken"]') : null;
            var token = tokenInput ? tokenInput.value : '';
            btn.disabled = true;
            btn.textContent = 'Sending...';

            fetch(config.sendUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                },
                body: '__RequestVerificationToken=' + encodeURIComponent(token) + '&email=' + encodeURIComponent(email)
            })
                .then(function (response) { return response.json(); })
                .then(function (data) {
                    if (!statusEl) return;
                    statusEl.textContent = data.message || (data.success ? 'OTP sent.' : 'Unable to send OTP.');
                    statusEl.className = 'otp-status ' + (data.success ? 'success' : 'error');
                })
                .catch(function () {
                    if (statusEl) {
                        statusEl.textContent = 'Unable to send OTP. Please try again.';
                        statusEl.className = 'otp-status error';
                    }
                })
                .finally(function () {
                    btn.disabled = false;
                    btn.textContent = 'Send OTP';
                });
        });
    }

    setupPasswordResetOtp({
        buttonId: 'donorSendOtpBtn',
        formId: 'donorForgotForm',
        emailInputId: 'donorForgotEmail',
        statusId: 'donorOtpStatus',
        emailRequiredMessage: 'Email is required to send OTP.',
        sendUrl: '@Url.Action("SendDonorPasswordResetOtp", "Account")'
    });

    setupPasswordResetOtp({
        buttonId: 'studentSendOtpBtn',
        formId: 'studentForgotForm',
        emailInputId: 'studentForgotEmail',
        statusId: 'studentOtpStatus',
        emailRequiredMessage: 'Email is required to send OTP.',
        sendUrl: '@Url.Action("SendStudentPasswordResetOtp", "Account")'
    });

    function clearFieldError(input) {
        if (!input) return;
        input.classList.remove('input-error');
        var holder = input.parentElement;
        if (!holder) return;
        var existing = holder.querySelector('.field-error');
        if (existing) {
            existing.remove();
        }
    }

    function showFieldError(input, message) {
        if (!input) return;
        clearFieldError(input);
        input.classList.add('input-error');
        var holder = input.parentElement;
        if (!holder) return;
        var err = document.createElement('div');
        err.className = 'field-error';
        err.textContent = message;
        holder.appendChild(err);
    }

    document.querySelectorAll('form.client-validate-form').forEach(function (form) {
        form.addEventListener('submit', function (e) {
            var valid = true;
            form.querySelectorAll('[required]').forEach(function (field) {
                clearFieldError(field);
                var value = (field.value || '').trim();
                if (!value) {
                    valid = false;
                    var label = field.getAttribute('data-label') || 'This field';
                    showFieldError(field, label + ' is required.');
                }
            });

            if (!valid) {
                e.preventDefault();
            }
        });

        form.querySelectorAll('[required]').forEach(function (field) {
            field.addEventListener('input', function () {
                if ((field.value || '').trim()) {
                    clearFieldError(field);
                }
            });
        });
    });

    renderRoleUI();
    if (showOtpDialog) {
        openOtpDialog();
    }
</script>
<style>
    .input-error {
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 3px rgba(239, 68, 68, .15) !important;
    }

    .field-error {
        margin-top: 6px;
        color: #dc2626;
        font-size: 12px;
        font-weight: 600;
    }

    .otp-status {
        font-size: 13px;
        font-weight: 600;
        line-height: 1.4;
    }

    .otp-status.success {
        color: #15803d;
    }

    .otp-status.error {
        color: #dc2626;
    }

    .otp-modal {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .otp-modal.active {
        display: flex;
    }

    .otp-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
    }

    .otp-content {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 24px 70px rgba(15, 23, 42, 0.2);
        padding: 28px 26px;
    }

    .otp-close {
        position: absolute;
        top: 14px;
        right: 14px;
        border: none;
        background: transparent;
        font-size: 24px;
        cursor: pointer;
        color: #334155;
    }

    .otp-content h3 {
        margin-top: 0;
        margin-bottom: 14px;
        font-size: 22px;
        font-weight: 800;
    }

    .otp-content p {
        margin-bottom: 20px;
        color: #475569;
        line-height: 1.5;
    }

    .otp-content .role-field {
        margin-bottom: 18px;
    }

    .otp-content .role-actions {
        text-align: right;
    }
</style>
